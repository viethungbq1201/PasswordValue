{
    "manifest_version": 3,
    "name": "SecureVault",
    "version": "1.0.0",
    "description": "Zero-knowledge password manager — autofill credentials securely",
    "permissions": [
        "storage",
        "activeTab",
        "alarms",
        "idle"
    ],
    "host_permissions": [
        "http://localhost:8080/*",
        "https://*.onrender.com/*",
        "https://*.up.railway.app/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content-styles.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}